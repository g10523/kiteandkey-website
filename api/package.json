        "express": "^4.18.2",
        "pg": "^8.11.3",
        "knex": "^3.1.0",
        "bcrypt": "^5.1.1",
        "jsonwebtoken": "^9.0.2",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "helmet": "^7.1.0",
        "express-rate-limit": "^7.1.5",
        "joi": "^17.11.0",
        "dotenv": "^16.3.1",
        "uuid": "^9.0.1",
        "nodemailer": "^6.9.7",
        "crypto": "^1.0.1"
    },
    "devDependencies": {
        "nodemon": "^3.0.2"
    },
